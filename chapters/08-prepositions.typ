  [op], [on, on top of], [`De sleutel ligt op de tafel.`],
  [onder], [under], [`De tas staat onder de stoel.`],
  [naast], [next to], [`Ik zit naast mijn vriend.`],
  [voor], [in front of, before], [`De fiets staat voor het huis.`],
  [achter], [behind], [`De tuin ligt achter het huis.`],
  [tussen], [between], [`Het station ligt tussen de winkels.`],
  [bij], [at, near, with], [`Wij zijn bij oma.`],
