{
  "name": "learn-dutch",
  "module": "index.ts",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "typst watch main.typ dist/learn-dutch.pdf",
    "build": "typst compile main.typ dist/learn-dutch.pdf",
    "lint": "eslint --pass-on-no-patterns",
    "format": "prettier --write .",
    "typstyle": "typstyle -i main.typ chapters/ frontmatter/ -v",
    "commit": "cz",
    "setup": "cargo binstall typstyle"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/bun": "latest",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
